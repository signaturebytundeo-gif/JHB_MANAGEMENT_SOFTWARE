// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ADMIN
  MANAGER
  SALES_REP
  INVESTOR
}

enum LocationType {
  PRODUCTION
  RESTAURANT
  WAREHOUSE
  FULFILLMENT
  MARKET
  EVENT
}

enum ChannelType {
  ONLINE
  RETAIL
  WHOLESALE
  MARKETPLACE
  SUBSCRIPTION
  EVENT
}

enum BatchStatus {
  PLANNED
  IN_PROGRESS
  QC_REVIEW
  RELEASED
  HOLD
}

enum ProductionSource {
  IN_HOUSE
  CO_PACKER
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  SQUARE
  STRIPE
  ZELLE
  CHECK
  NET_30
  AMAZON_PAY
  OTHER
}

enum AdjustmentReason {
  DAMAGE
  THEFT
  COUNTING_ERROR
  TRANSFER
  OTHER
}

enum MovementType {
  PRODUCTION
  TRANSFER
  ADJUSTMENT
  ALLOCATION
  DEDUCTION
}

enum InventoryAdjustmentReason {
  DAMAGE
  SHRINKAGE
  SAMPLING
  EXPIRED
  COUNT_CORRECTION
}

enum TransactionType {
  BATCH_COMPLETION
  TRANSFER_IN
  TRANSFER_OUT
  SALE_DEDUCTION
  ADJUSTMENT
}

enum ShipmentStatus {
  DRAFT
  LABEL_CREATED
  SHIPPED
  DELIVERED
  VOIDED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OperatorOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum OperatorOrderType {
  STANDARD
  CATERING
  FARMERS_MARKET
}

enum OrderSource {
  WEBSITE
  AMAZON
  ETSY
}

enum SyncPlatform {
  SQUARE
  AMAZON
  ETSY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// ============================================================================
// USER & AUTHENTICATION MODELS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String?   // Nullable for magic link users
  role          Role      @default(SALES_REP)
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  invitesSent           InviteToken[]
  createdBatches        Batch[]
  conductedQCTests      QCTest[]
  createdSales          Sale[]
  stockAdjustments      StockAdjustment[]
  inventoryTransactions InventoryTransaction[]
  shipments             Shipment[]
  marketplaceSyncs      MarketplaceSync[]
  createdMovements      InventoryMovement[] @relation("MovementCreator")
  approvedMovements     InventoryMovement[] @relation("MovementApprover")
  createdOrders         Order[]             @relation("OrderCreator")
  approvedOrders        Order[]             @relation("OrderApprover")
  secondApprovedOrders  Order[]             @relation("OrderSecondApprover")
  invoicePayments       InvoicePayment[]

  @@index([email])
  @@index([role])
}

model InviteToken {
  id          String    @id @default(cuid())
  email       String
  role        Role
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  invitedBy User @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([token])
  @@index([email])
}

// ============================================================================
// PRODUCT & PRICING MODELS
// ============================================================================

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  size          String
  unitsPerCase  Int?     // Nullable for TBD packaging
  description   String?
  reorderPoint  Int      @default(0)  // Default reorder threshold in units
  leadTimeDays  Int      @default(14) // Default production/procurement lead time
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  pricingTiers          PricingTier[]
  batches               Batch[]
  sales                 Sale[]
  stockAdjustments      StockAdjustment[]
  inventoryTransactions InventoryTransaction[]
  orderLineItems        OrderLineItem[]

  @@index([sku])
  @@index([isActive])
}

model PricingTier {
  id         String   @id @default(cuid())
  productId  String
  tierName   String   // e.g., "Wholesale Cash", "Wholesale Net 30", "Retail"
  unitPrice  Decimal
  casePrice  Decimal?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tierName])
  @@index([productId])
}

model VolumeDiscount {
  id              String   @id @default(cuid())
  minCases        Int
  maxCases        Int?     // Nullable for unlimited (11+)
  discountPercent Decimal
  description     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([minCases])
}

model FrequencyDiscount {
  id                 String   @id @default(cuid())
  frequency          String   // "quarterly" or "annual"
  discountPercent    Decimal
  additionalBenefits String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([frequency])
}

// ============================================================================
// LOCATION & SALES CHANNEL MODELS
// ============================================================================

model Location {
  id               String            @id @default(cuid())
  name             String            @unique
  type             LocationType
  address          String?
  description      String?
  deliverySchedule String?           // e.g., "Weekly delivery"
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  batchAllocations      BatchAllocation[]
  stockAdjustments      StockAdjustment[]
  inventoryTransactions InventoryTransaction[]
  shipments             Shipment[]
  movementsFrom         InventoryMovement[] @relation("FromLocation")
  movementsTo           InventoryMovement[] @relation("ToLocation")
  orders                Order[]

  @@index([name])
  @@index([type])
  @@index([isActive])
}

model SalesChannel {
  id          String      @id @default(cuid())
  name        String      @unique
  type        ChannelType
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  sales  Sale[]
  orders Order[]

  @@index([name])
  @@index([type])
  @@index([isActive])
}

// ============================================================================
// SUBSCRIPTION & APPROVAL MODELS
// ============================================================================

model SubscriptionPlan {
  id                 String   @id @default(cuid())
  name               String   @unique
  billingCycle       String   // "monthly" or "annual"
  price              Decimal
  includedProducts   String   // Description of what's included
  loyaltyReward      String?  // e.g., "1 month free at 6 months"
  cancellationPolicy String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([name])
  @@index([billingCycle])
  @@index([isActive])
}

model ApprovalThreshold {
  id           String   @id @default(cuid())
  minAmount    Decimal
  maxAmount    Decimal? // Nullable for unlimited
  approvalType String   // "auto", "single_member", "dual_member", "dual_bank"
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([minAmount])
}

// ============================================================================
// PRODUCTION & QUALITY CONTROL MODELS
// ============================================================================

model CoPackerPartner {
  id          String   @id @default(cuid())
  name        String   @unique
  contactName String?
  email       String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  batches Batch[]

  @@index([name])
  @@index([isActive])
}

model Batch {
  id                     String           @id @default(cuid())
  batchCode              String           @unique
  productId              String
  productionDate         DateTime         @default(now())
  productionSource       ProductionSource
  status                 BatchStatus      @default(PLANNED)
  totalUnits             Int
  notes                  String?
  coPackerPartnerId      String?
  coPackerLotNumber      String?
  coPackerReceivingDate  DateTime?
  createdById            String
  isActive               Boolean          @default(true)
  deletedAt              DateTime?
  deletedReason          String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  // Relations
  product            Product            @relation(fields: [productId], references: [id])
  coPackerPartner    CoPackerPartner?   @relation(fields: [coPackerPartnerId], references: [id])
  createdBy          User               @relation(fields: [createdById], references: [id])
  qcTests            QCTest[]
  allocations        BatchAllocation[]
  materials          BatchMaterial[]
  inventoryMovements InventoryMovement[]

  @@index([batchCode])
  @@index([productId])
  @@index([status])
  @@index([productionDate])
  @@index([isActive])
  @@index([coPackerPartnerId])
}

model QCTest {
  id         String   @id @default(cuid())
  batchId    String
  testType   String
  phLevel    Decimal?
  passed     Boolean
  notes      String?
  testedById String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  batch    Batch @relation(fields: [batchId], references: [id])
  testedBy User  @relation(fields: [testedById], references: [id])

  @@index([batchId])
  @@index([testType])
}

model BatchAllocation {
  id         String   @id @default(cuid())
  batchId    String
  locationId String
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  batch    Batch    @relation(fields: [batchId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([batchId, locationId])
  @@index([batchId])
  @@index([locationId])
}

model RawMaterial {
  id             String          @id @default(cuid())
  name           String
  supplier       String
  lotNumber      String
  expirationDate DateTime
  receivedDate   DateTime
  quantity       Decimal
  unit           String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  batchMaterials BatchMaterial[]

  @@index([name])
  @@index([supplier])
  @@index([lotNumber])
  @@index([isActive])
}

model BatchMaterial {
  id            String   @id @default(cuid())
  batchId       String
  rawMaterialId String
  quantityUsed  Decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  batch       Batch       @relation(fields: [batchId], references: [id])
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@unique([batchId, rawMaterialId])
}

// ============================================================================
// INVENTORY MODEL
// ============================================================================

model InventoryMovement {
  id               String                     @id @default(cuid())
  movementType     MovementType
  batchId          String
  fromLocationId   String?
  toLocationId     String?
  quantity         Int                        // Always positive; direction determined by from/to
  reason           InventoryAdjustmentReason? // Required for ADJUSTMENT type
  notes            String?
  requiresApproval Boolean                    @default(false)
  approvedById     String?
  approvedAt       DateTime?
  createdById      String
  orderId          String?
  createdAt        DateTime                   @default(now())

  // Relations
  batch        Batch     @relation(fields: [batchId], references: [id])
  fromLocation Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])
  approvedBy   User?     @relation("MovementApprover", fields: [approvedById], references: [id])
  createdBy    User      @relation("MovementCreator", fields: [createdById], references: [id])
  order        Order?    @relation("OrderMovements", fields: [orderId], references: [id])

  @@index([batchId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([movementType])
  @@index([createdAt])
  @@index([createdById])
}

model PackagingMaterial {
  id              String    @id @default(cuid())
  name            String    // e.g., "5oz Glass Bottle", "Standard Cap", "Front Label"
  type            String    // BOTTLE, CAP, LABEL, BOX, OTHER
  supplier        String
  currentQuantity Int       @default(0)
  unit            String    // e.g., "units", "rolls", "sheets"
  reorderPoint    Int       @default(0)
  leadTimeDays    Int       @default(14)
  costPerUnit     Decimal?
  lastOrderDate   DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
  @@index([type])
  @@index([isActive])
}

model StockAdjustment {
  id             String           @id @default(cuid())
  productId      String
  locationId     String?
  quantityChange Int              // positive = add, negative = subtract
  reason         AdjustmentReason
  notes          String?
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  product   Product   @relation(fields: [productId], references: [id])
  location  Location? @relation(fields: [locationId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([createdById])
  @@index([reason])
}

model InventoryTransaction {
  id             String          @id @default(cuid())
  productId      String
  locationId     String
  type           TransactionType
  quantityChange Int             // positive = add, negative = subtract
  referenceId    String?         // batchId, saleId, or transfer pair ID
  reason         String?         // For ADJUSTMENT type (e.g., "Damage", "Counting Error")
  notes          String?
  createdById    String
  createdAt      DateTime        @default(now())

  // Relations
  product   Product  @relation(fields: [productId], references: [id])
  location  Location @relation(fields: [locationId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceId])
}

// ============================================================================
// SALES MODEL
// ============================================================================

model Sale {
  id              String        @id @default(cuid())
  saleDate        DateTime
  channelId       String
  productId       String
  quantity        Int
  unitPrice       Decimal
  totalAmount     Decimal
  paymentMethod   PaymentMethod
  referenceNumber String?
  notes           String?
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  channel   SalesChannel @relation(fields: [channelId], references: [id])
  product   Product      @relation(fields: [productId], references: [id])
  createdBy User         @relation(fields: [createdById], references: [id])

  @@index([saleDate])
  @@index([channelId])
  @@index([productId])
  @@index([createdById])
  @@index([paymentMethod])
}

// ============================================================================
// SHIPPING MODEL
// ============================================================================

model Shipment {
  id                String          @id @default(cuid())
  status            ShipmentStatus  @default(DRAFT)

  // Recipient
  recipientName     String
  recipientEmail    String?
  recipientPhone    String?
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  zip               String
  country           String          @default("US")

  // Package
  weight            Decimal         // lbs
  length            Decimal?        // inches
  width             Decimal?
  height            Decimal?

  // Shipment details
  serviceCode       String          @default("03") // 03 = UPS Ground
  shipFromLocationId String?

  // UPS response data
  trackingNumber    String?
  labelData         String?         // base64-encoded label image (PNG)
  labelFormat       String?         // PNG, ZPL, etc.
  shippingCost      Decimal?        // in dollars

  // Order reference
  stripePaymentIntentId String?     // Link to website order
  orderNotes        String?
  items             String?         // JSON string of items in shipment

  createdById       String
  shippedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  createdBy        User      @relation(fields: [createdById], references: [id])
  shipFromLocation Location? @relation(fields: [shipFromLocationId], references: [id])

  @@index([status])
  @@index([trackingNumber])
  @@index([stripePaymentIntentId])
  @@index([createdAt])
}

// ============================================================================
// CUSTOMER & WEBSITE ORDER MODELS
// ============================================================================

model Customer {
  id         String   @id @default(cuid())
  email      String   @unique
  firstName  String
  lastName   String
  phone      String?
  orderCount Int      @default(0)
  totalSpent Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  orders         WebsiteOrder[]
  operatorOrders Order[]         @relation("CustomerOperatorOrders")
  invoices       Invoice[]

  @@index([email])
  @@index([lastName])
}

model WebsiteOrder {
  id             String      @id @default(cuid())
  orderId        String      @unique // from website (e.g. Stripe PI id)
  stripeEventId  String?     @unique // Stripe checkout.session.completed event ID — idempotency key
  customerId     String
  items          String      // JSON array of line items
  shippingCost   Decimal
  orderTotal     Decimal
  status         OrderStatus @default(NEW)
  source         OrderSource @default(WEBSITE)
  orderDate      DateTime
  trackingNumber          String?
  carrier                 String?
  shippedAt               DateTime?
  confirmationEmailSentAt DateTime?
  shippingEmailSentAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([orderDate])
  @@index([customerId])
  @@index([source])
}

// ============================================================================
// MARKETPLACE SYNC MODEL
// ============================================================================

model MarketplaceSync {
  id              String       @id @default(cuid())
  platform        SyncPlatform
  status          SyncStatus   @default(RUNNING)
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  recordsFound    Int          @default(0)
  recordsCreated  Int          @default(0)
  recordsSkipped  Int          @default(0)
  errorMessage    String?
  errorDetails    String?      // JSON string of detailed errors
  triggeredById   String?

  // Relations
  triggeredBy User? @relation(fields: [triggeredById], references: [id])

  @@index([platform])
  @@index([status])
  @@index([startedAt])
}

// ============================================================================
// ORDER MANAGEMENT MODELS (Phase 4)
// ============================================================================

model Order {
  id                 String              @id @default(cuid())
  orderNumber        String              @unique
  status             OperatorOrderStatus @default(DRAFT)
  orderType          OperatorOrderType   @default(STANDARD)
  customerId         String?
  channelId          String
  locationId         String
  paymentMethod      PaymentMethod
  orderDate          DateTime            @default(now())
  notes              String?

  // Catering-specific fields (ORD-09)
  depositAmount      Decimal?
  depositPaidAt      DateTime?
  balanceDueDate     DateTime?
  eventDate          DateTime?

  // Farmers market / event fields (ORD-08)
  eventLocation      String?
  weatherNotes       String?
  footTrafficNotes   String?

  // Approval tracking (ORD-06)
  totalAmount        Decimal             @default(0)
  approvalStatus     String?
  approvedById       String?
  secondApprovedById String?
  approvedAt         DateTime?

  // Audit
  createdById        String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations
  customer           Customer?           @relation("CustomerOperatorOrders", fields: [customerId], references: [id])
  channel            SalesChannel        @relation(fields: [channelId], references: [id])
  location           Location            @relation(fields: [locationId], references: [id])
  createdBy          User                @relation("OrderCreator", fields: [createdById], references: [id])
  approvedBy         User?               @relation("OrderApprover", fields: [approvedById], references: [id])
  secondApprovedBy   User?               @relation("OrderSecondApprover", fields: [secondApprovedById], references: [id])
  lineItems          OrderLineItem[]
  invoice            Invoice?
  inventoryMovements InventoryMovement[] @relation("OrderMovements")

  @@index([status])
  @@index([customerId])
  @@index([channelId])
  @@index([orderDate])
  @@index([orderType])
}

model OrderLineItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Decimal
  totalPrice Decimal

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  orderId       String        @unique
  customerId    String?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal
  taxAmount     Decimal       @default(0)
  totalAmount   Decimal
  paidAmount    Decimal       @default(0)
  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  viewedAt      DateTime?
  overdueAt     DateTime?
  lateFeeAmount Decimal       @default(0)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  order    Order            @relation(fields: [orderId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  payments InvoicePayment[]

  @@index([status])
  @@index([customerId])
  @@index([dueDate])
  @@index([issuedAt])
}

model InvoicePayment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal
  paymentMethod PaymentMethod
  paidAt        DateTime
  notes         String?
  createdById   String
  createdAt     DateTime      @default(now())

  // Relations
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([invoiceId])
  @@index([paidAt])
}
