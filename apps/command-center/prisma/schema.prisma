// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum CustomerType {
  RETAIL
  WHOLESALE
  DISTRIBUTOR
  RESTAURANT
  SUBSCRIPTION
  EVENT
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum LeadStage {
  LEAD
  CONTACTED
  MEETING
  PROPOSAL
  NEGOTIATION
  CLOSED
}

enum Role {
  ADMIN
  MANAGER
  SALES_REP
  INVESTOR
}

enum LocationType {
  PRODUCTION
  RESTAURANT
  WAREHOUSE
  FULFILLMENT
  MARKET
  EVENT
}

enum ChannelType {
  ONLINE
  RETAIL
  WHOLESALE
  MARKETPLACE
  SUBSCRIPTION
  EVENT
}

enum BatchStatus {
  PLANNED
  IN_PROGRESS
  QC_REVIEW
  RELEASED
  HOLD
}

enum ProductionSource {
  IN_HOUSE
  CO_PACKER
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  SQUARE
  STRIPE
  ZELLE
  CHECK
  NET_30
  AMAZON_PAY
  OTHER
}

enum AdjustmentReason {
  DAMAGE
  THEFT
  COUNTING_ERROR
  TRANSFER
  OTHER
}

enum MovementType {
  PRODUCTION
  TRANSFER
  ADJUSTMENT
  ALLOCATION
  DEDUCTION
}

enum InventoryAdjustmentReason {
  DAMAGE
  SHRINKAGE
  SAMPLING
  EXPIRED
  COUNT_CORRECTION
}

enum TransactionType {
  BATCH_COMPLETION
  TRANSFER_IN
  TRANSFER_OUT
  SALE_DEDUCTION
  ADJUSTMENT
}

enum ShipmentStatus {
  DRAFT
  LABEL_CREATED
  SHIPPED
  DELIVERED
  VOIDED
}

enum OrderStatus {
  NEW
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OperatorOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum OperatorOrderType {
  STANDARD
  CATERING
  FARMERS_MARKET
}

enum OrderSource {
  WEBSITE
  AMAZON
  ETSY
}

enum SyncPlatform {
  SQUARE
  AMAZON
  ETSY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// ============================================================================
// USER & AUTHENTICATION MODELS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String? // Nullable for magic link users
  role          Role      @default(SALES_REP)
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  invitesSent            InviteToken[]
  createdBatches         Batch[]
  conductedQCTests       QCTest[]
  createdSales           Sale[]
  stockAdjustments       StockAdjustment[]
  inventoryTransactions  InventoryTransaction[]
  shipments              Shipment[]
  marketplaceSyncs       MarketplaceSync[]
  createdMovements       InventoryMovement[]    @relation("MovementCreator")
  approvedMovements      InventoryMovement[]    @relation("MovementApprover")
  createdOrders          Order[]                @relation("OrderCreator")
  approvedOrders         Order[]                @relation("OrderApprover")
  secondApprovedOrders   Order[]                @relation("OrderSecondApprover")
  invoicePayments        InvoicePayment[]
  leadsAssigned          Lead[]                 @relation("LeadAssignee")
  leadsCreated           Lead[]                 @relation("LeadCreator")
  expensesCreated        Expense[]              @relation("ExpenseCreator")
  expensesApproved       Expense[]              @relation("ExpenseApprover")
  expensesSecondApproved Expense[]              @relation("ExpenseSecondApprover")
  documentsUploaded      Document[]             @relation("DocumentUploader")
  versionsUploaded       DocumentVersion[]      @relation("VersionUploader")
  createdEvents          MarketEvent[]

  @@index([email])
  @@index([role])
}

model InviteToken {
  id          String    @id @default(cuid())
  email       String
  role        Role
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  invitedBy User @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([token])
  @@index([email])
}

// ============================================================================
// PRODUCT & PRICING MODELS
// ============================================================================

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String   @unique
  size         String
  unitsPerCase Int? // Nullable for TBD packaging
  description  String?
  reorderPoint Int      @default(0) // Default reorder threshold in units
  leadTimeDays Int      @default(14) // Default production/procurement lead time
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  pricingTiers          PricingTier[]
  batches               Batch[]
  sales                 Sale[]
  stockAdjustments      StockAdjustment[]
  inventoryTransactions InventoryTransaction[]
  orderLineItems        OrderLineItem[]
  invoiceLineItems      InvoiceLineItem[]
  promotionalPricings   PromotionalPricing[]

  @@index([sku])
  @@index([isActive])
}

model PricingTier {
  id        String   @id @default(cuid())
  productId String
  tierName  String // e.g., "Wholesale Cash", "Wholesale Net 30", "Retail"
  unitPrice Decimal
  casePrice Decimal?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tierName])
  @@index([productId])
}

model VolumeDiscount {
  id              String   @id @default(cuid())
  minCases        Int
  maxCases        Int? // Nullable for unlimited (11+)
  discountPercent Decimal
  description     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([minCases])
}

model FrequencyDiscount {
  id                 String   @id @default(cuid())
  frequency          String // "quarterly" or "annual"
  discountPercent    Decimal
  additionalBenefits String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([frequency])
}

// ============================================================================
// LOCATION & SALES CHANNEL MODELS
// ============================================================================

model Location {
  id               String       @id @default(cuid())
  name             String       @unique
  type             LocationType
  address          String?
  description      String?
  deliverySchedule String? // e.g., "Weekly delivery"
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  batchAllocations      BatchAllocation[]
  stockAdjustments      StockAdjustment[]
  inventoryTransactions InventoryTransaction[]
  shipments             Shipment[]
  movementsFrom         InventoryMovement[]    @relation("FromLocation")
  movementsTo           InventoryMovement[]    @relation("ToLocation")
  orders                Order[]

  @@index([name])
  @@index([type])
  @@index([isActive])
}

model SalesChannel {
  id          String      @id @default(cuid())
  name        String      @unique
  type        ChannelType
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  sales  Sale[]
  orders Order[]
  events MarketEvent[]

  @@index([name])
  @@index([type])
  @@index([isActive])
}

model MarketEvent {
  id          String   @id @default(cuid())
  name        String
  eventDate   DateTime
  location    String?
  boothFee    Decimal  @default(0)
  travelCost  Decimal  @default(0)
  supplyCost  Decimal  @default(0)
  laborCost   Decimal  @default(0)
  otherCost   Decimal  @default(0)
  notes       String?
  channelId   String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  channel   SalesChannel @relation(fields: [channelId], references: [id])
  createdBy User         @relation(fields: [createdById], references: [id])
  sales     Sale[]

  @@index([eventDate])
  @@index([channelId])
  @@index([createdById])
}

// ============================================================================
// SUBSCRIPTION & APPROVAL MODELS
// ============================================================================

model SubscriptionPlan {
  id                 String   @id @default(cuid())
  name               String   @unique
  billingCycle       String // "monthly" or "annual"
  price              Decimal
  includedProducts   String // Description of what's included
  loyaltyReward      String? // e.g., "1 month free at 6 months"
  cancellationPolicy String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  members SubscriptionMember[] @relation("PlanMembers")

  @@index([name])
  @@index([billingCycle])
  @@index([isActive])
}

model ApprovalThreshold {
  id           String   @id @default(cuid())
  minAmount    Decimal
  maxAmount    Decimal? // Nullable for unlimited
  approvalType String // "auto", "single_member", "dual_member", "dual_bank"
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([minAmount])
}

// ============================================================================
// PRODUCTION & QUALITY CONTROL MODELS
// ============================================================================

model CoPackerPartner {
  id          String   @id @default(cuid())
  name        String   @unique
  contactName String?
  email       String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  batches Batch[]

  @@index([name])
  @@index([isActive])
}

model Batch {
  id                    String           @id @default(cuid())
  batchCode             String           @unique
  productId             String
  productionDate        DateTime         @default(now())
  productionSource      ProductionSource
  status                BatchStatus      @default(PLANNED)
  totalUnits            Int
  notes                 String?
  coPackerPartnerId     String?
  coPackerLotNumber     String?
  coPackerReceivingDate DateTime?
  laborCostTotal        Decimal?         @default(0)
  overheadCostTotal     Decimal?         @default(0)
  createdById           String
  isActive              Boolean          @default(true)
  deletedAt             DateTime?
  deletedReason         String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // Relations
  product            Product             @relation(fields: [productId], references: [id])
  coPackerPartner    CoPackerPartner?    @relation(fields: [coPackerPartnerId], references: [id])
  createdBy          User                @relation(fields: [createdById], references: [id])
  qcTests            QCTest[]
  allocations        BatchAllocation[]
  materials          BatchMaterial[]
  inventoryMovements InventoryMovement[]
  documents          Document[]          @relation("BatchDocuments")

  @@index([batchCode])
  @@index([productId])
  @@index([status])
  @@index([productionDate])
  @@index([isActive])
  @@index([coPackerPartnerId])
}

model QCTest {
  id         String   @id @default(cuid())
  batchId    String
  testType   String
  phLevel    Decimal?
  passed     Boolean
  notes      String?
  testedById String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  batch    Batch @relation(fields: [batchId], references: [id])
  testedBy User  @relation(fields: [testedById], references: [id])

  @@index([batchId])
  @@index([testType])
}

model BatchAllocation {
  id         String   @id @default(cuid())
  batchId    String
  locationId String
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  batch    Batch    @relation(fields: [batchId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([batchId, locationId])
  @@index([batchId])
  @@index([locationId])
}

model RawMaterial {
  id             String   @id @default(cuid())
  name           String
  supplier       String
  lotNumber      String
  expirationDate DateTime
  receivedDate   DateTime
  quantity       Decimal
  unit           String
  costPerUnit    Decimal?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  batchMaterials BatchMaterial[]

  @@index([name])
  @@index([supplier])
  @@index([lotNumber])
  @@index([isActive])
}

model BatchMaterial {
  id            String   @id @default(cuid())
  batchId       String
  rawMaterialId String
  quantityUsed  Decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  batch       Batch       @relation(fields: [batchId], references: [id])
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@unique([batchId, rawMaterialId])
}

// ============================================================================
// INVENTORY MODEL
// ============================================================================

model InventoryMovement {
  id               String                     @id @default(cuid())
  movementType     MovementType
  batchId          String
  fromLocationId   String?
  toLocationId     String?
  quantity         Int // Always positive; direction determined by from/to
  reason           InventoryAdjustmentReason? // Required for ADJUSTMENT type
  notes            String?
  requiresApproval Boolean                    @default(false)
  approvedById     String?
  approvedAt       DateTime?
  createdById      String
  orderId          String?
  createdAt        DateTime                   @default(now())

  // Relations
  batch        Batch     @relation(fields: [batchId], references: [id])
  fromLocation Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])
  approvedBy   User?     @relation("MovementApprover", fields: [approvedById], references: [id])
  createdBy    User      @relation("MovementCreator", fields: [createdById], references: [id])
  order        Order?    @relation("OrderMovements", fields: [orderId], references: [id])

  @@index([batchId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([movementType])
  @@index([createdAt])
  @@index([createdById])
}

model PackagingMaterial {
  id              String    @id @default(cuid())
  name            String // e.g., "5oz Glass Bottle", "Standard Cap", "Front Label"
  type            String // BOTTLE, CAP, LABEL, BOX, OTHER
  supplier        String
  currentQuantity Int       @default(0)
  unit            String // e.g., "units", "rolls", "sheets"
  reorderPoint    Int       @default(0)
  leadTimeDays    Int       @default(14)
  costPerUnit     Decimal?
  lastOrderDate   DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
  @@index([type])
  @@index([isActive])
}

model StockAdjustment {
  id             String           @id @default(cuid())
  productId      String
  locationId     String?
  quantityChange Int // positive = add, negative = subtract
  reason         AdjustmentReason
  notes          String?
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  product   Product   @relation(fields: [productId], references: [id])
  location  Location? @relation(fields: [locationId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([createdById])
  @@index([reason])
}

model InventoryTransaction {
  id             String          @id @default(cuid())
  productId      String
  locationId     String
  type           TransactionType
  quantityChange Int // positive = add, negative = subtract
  referenceId    String? // batchId, saleId, or transfer pair ID
  reason         String? // For ADJUSTMENT type (e.g., "Damage", "Counting Error")
  notes          String?
  createdById    String
  createdAt      DateTime        @default(now())

  // Relations
  product   Product  @relation(fields: [productId], references: [id])
  location  Location @relation(fields: [locationId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceId])
}

// ============================================================================
// SALES MODEL
// ============================================================================

model Sale {
  id              String        @id @default(cuid())
  saleDate        DateTime
  channelId       String
  productId       String
  eventId         String?
  quantity        Int
  unitPrice       Decimal
  totalAmount     Decimal
  paymentMethod   PaymentMethod
  referenceNumber String?
  notes           String?
  isPromo         Boolean       @default(false) // Promo/giveaway — $0 price, excluded from revenue
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  channel   SalesChannel @relation(fields: [channelId], references: [id])
  product   Product      @relation(fields: [productId], references: [id])
  event     MarketEvent? @relation(fields: [eventId], references: [id])
  createdBy User         @relation(fields: [createdById], references: [id])

  @@index([saleDate])
  @@index([channelId])
  @@index([productId])
  @@index([eventId])
  @@index([createdById])
  @@index([paymentMethod])
  @@index([isPromo])
}

// ============================================================================
// SHIPPING MODEL
// ============================================================================

model Shipment {
  id     String         @id @default(cuid())
  status ShipmentStatus @default(DRAFT)

  // Recipient
  recipientName  String
  recipientEmail String?
  recipientPhone String?
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  zip            String
  country        String  @default("US")

  // Package
  weight Decimal // lbs
  length Decimal? // inches
  width  Decimal?
  height Decimal?

  // Shipment details
  serviceCode        String  @default("03") // 03 = UPS Ground
  shipFromLocationId String?

  // UPS response data
  trackingNumber String?
  labelData      String? // base64-encoded label image (PNG)
  labelFormat    String? // PNG, ZPL, etc.
  shippingCost   Decimal? // in dollars

  // Order reference
  stripePaymentIntentId String? // Link to website order
  orderNotes            String?
  items                 String? // JSON string of items in shipment

  // EasyPost integration fields
  easypostShipmentId String? // EasyPost shp_... ID — needed for refund/void calls
  websiteOrderId     String? // FK to WebsiteOrder — links shipment to any order source

  createdById String
  shippedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  createdBy        User          @relation(fields: [createdById], references: [id])
  shipFromLocation Location?     @relation(fields: [shipFromLocationId], references: [id])
  websiteOrder     WebsiteOrder? @relation(fields: [websiteOrderId], references: [id])

  @@index([status])
  @@index([trackingNumber])
  @@index([stripePaymentIntentId])
  @@index([createdAt])
  @@index([websiteOrderId])
}

// ============================================================================
// CUSTOMER & WEBSITE ORDER MODELS
// ============================================================================

model Customer {
  id         String  @id @default(cuid())
  email      String  @unique
  firstName  String
  lastName   String
  phone      String?
  orderCount Int     @default(0)
  totalSpent Decimal @default(0)

  // CRM fields (Phase 5)
  customerType    CustomerType @default(RETAIL)
  company         String?
  paymentTerms    String? // "net_30", "net_15", "cash"
  creditLimit     Decimal?
  billingAddress  String?
  shippingAddress String?
  city            String?
  state           String?
  zip             String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders                WebsiteOrder[]
  operatorOrders        Order[]                @relation("CustomerOperatorOrders")
  invoices              Invoice[]
  distributorAgreements DistributorAgreement[]
  subscriptionMembers   SubscriptionMember[]   @relation("CustomerSubscriptions")
  documents             Document[]             @relation("CustomerDocuments")

  @@index([email])
  @@index([lastName])
  @@index([customerType])
}

model WebsiteOrder {
  id                      String      @id @default(cuid())
  orderId                 String      @unique // from website (e.g. Stripe PI id)
  stripeEventId           String?     @unique // Stripe checkout.session.completed event ID — idempotency key
  customerId              String
  items                   String // JSON array of line items
  shippingCost            Decimal
  orderTotal              Decimal
  status                  OrderStatus @default(NEW)
  source                  OrderSource @default(WEBSITE)
  orderDate               DateTime
  promoCode               String? // Sales rep promo code used (e.g. "AJBAR26")
  promoDiscount           Decimal? // Discount amount applied (in dollars)
  trackingNumber          String?
  carrier                 String?
  shippedAt               DateTime?
  confirmationEmailSentAt DateTime?
  shippingEmailSentAt     DateTime?
  deliveryEmailSentAt     DateTime?

  // Shipping address fields (extracted from marketplace orders or entered manually)
  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingState        String?
  shippingZip          String?
  shippingCountry      String? @default("US")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer  Customer   @relation(fields: [customerId], references: [id])
  shipments Shipment[]

  @@index([status])
  @@index([orderDate])
  @@index([customerId])
  @@index([source])
}

// ============================================================================
// MARKETPLACE SYNC MODEL
// ============================================================================

model MarketplaceSync {
  id             String       @id @default(cuid())
  platform       SyncPlatform
  status         SyncStatus   @default(RUNNING)
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  recordsFound   Int          @default(0)
  recordsCreated Int          @default(0)
  recordsSkipped Int          @default(0)
  errorMessage   String?
  errorDetails   String? // JSON string of detailed errors
  triggeredById  String?

  // Relations
  triggeredBy User? @relation(fields: [triggeredById], references: [id])

  @@index([platform])
  @@index([status])
  @@index([startedAt])
}

// ============================================================================
// ORDER MANAGEMENT MODELS (Phase 4)
// ============================================================================

model Order {
  id            String              @id @default(cuid())
  orderNumber   String              @unique
  status        OperatorOrderStatus @default(DRAFT)
  orderType     OperatorOrderType   @default(STANDARD)
  customerId    String?
  channelId     String
  locationId    String
  paymentMethod PaymentMethod
  orderDate     DateTime            @default(now())
  notes         String?

  // Catering-specific fields (ORD-09)
  depositAmount  Decimal?
  depositPaidAt  DateTime?
  balanceDueDate DateTime?
  eventDate      DateTime?

  // Farmers market / event fields (ORD-08)
  eventLocation    String?
  weatherNotes     String?
  footTrafficNotes String?

  // Approval tracking (ORD-06)
  totalAmount        Decimal   @default(0)
  approvalStatus     String?
  approvedById       String?
  secondApprovedById String?
  approvedAt         DateTime?

  // Audit
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  customer           Customer?           @relation("CustomerOperatorOrders", fields: [customerId], references: [id])
  channel            SalesChannel        @relation(fields: [channelId], references: [id])
  location           Location            @relation(fields: [locationId], references: [id])
  createdBy          User                @relation("OrderCreator", fields: [createdById], references: [id])
  approvedBy         User?               @relation("OrderApprover", fields: [approvedById], references: [id])
  secondApprovedBy   User?               @relation("OrderSecondApprover", fields: [secondApprovedById], references: [id])
  lineItems          OrderLineItem[]
  invoice            Invoice?
  inventoryMovements InventoryMovement[] @relation("OrderMovements")
  documents          Document[]          @relation("OrderDocuments")

  @@index([status])
  @@index([customerId])
  @@index([channelId])
  @@index([orderDate])
  @@index([orderType])
}

model OrderLineItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  unitPrice       Decimal
  totalPrice      Decimal
  discountPercent Decimal? // Discount applied (volume, frequency, or promotional)
  discountReason  String? // "volume", "frequency", "promotional"

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  orderId       String?       @unique
  customerId    String?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal
  taxAmount     Decimal       @default(0)
  totalAmount   Decimal
  paidAmount    Decimal       @default(0)
  issuedAt      DateTime?
  dueDate       DateTime?
  paidAt        DateTime?
  viewedAt      DateTime?
  overdueAt     DateTime?
  lateFeeAmount Decimal       @default(0)
  notes         String?
  paymentLink   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  order     Order?            @relation(fields: [orderId], references: [id])
  customer  Customer?         @relation(fields: [customerId], references: [id])
  payments  InvoicePayment[]
  lineItems InvoiceLineItem[]

  @@index([status])
  @@index([customerId])
  @@index([dueDate])
  @@index([issuedAt])
}

model InvoiceLineItem {
  id           String  @id @default(cuid())
  invoiceId    String
  description  String
  productId    String?
  quantity     Int
  unitPrice    Decimal
  totalPrice   Decimal
  deliveryNote String?

  // Relations
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

model InvoicePayment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal
  paymentMethod PaymentMethod
  paidAt        DateTime
  notes         String?
  createdById   String
  createdAt     DateTime      @default(now())

  // Relations
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([invoiceId])
  @@index([paidAt])
}

// ============================================================================
// FINANCIAL MANAGEMENT MODELS (Phase 6)
// ============================================================================

enum ExpenseCategory {
  INGREDIENTS
  PACKAGING
  LABOR
  EQUIPMENT
  MARKETING
  SHIPPING
  UTILITIES
  RENT
  INSURANCE
  OVERHEAD
  OTHER
}

enum DocumentCategory {
  AGREEMENT
  INVOICE
  CERTIFICATION
  SOP
  MARKETING
  TEMPLATE
  OTHER
}

model Expense {
  id                   String          @id @default(cuid())
  description          String
  amount               Decimal
  category             ExpenseCategory
  expenseDate          DateTime
  receiptUrl           String?
  vendorName           String?
  notes                String?
  approvalStatus       String? // "auto_approved", "pending_single", "pending_dual", "pending_bank", "approved", "rejected"
  approvedById         String?
  secondApprovedById   String?
  approvedAt           DateTime?
  bankAuthorizationRef String?
  createdById          String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  // Relations
  createdBy        User  @relation("ExpenseCreator", fields: [createdById], references: [id])
  approvedBy       User? @relation("ExpenseApprover", fields: [approvedById], references: [id])
  secondApprovedBy User? @relation("ExpenseSecondApprover", fields: [secondApprovedById], references: [id])

  @@index([expenseDate])
  @@index([category])
  @@index([approvalStatus])
  @@index([createdById])
}

model Budget {
  id             String          @id @default(cuid())
  period         String // "YYYY-MM"
  category       ExpenseCategory
  budgetedAmount Decimal
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([period, category])
  @@index([period])
}

// ============================================================================
// CRM MODELS (Phase 5)
// ============================================================================

model DistributorAgreement {
  id             String    @id @default(cuid())
  customerId     String
  territory      String
  commissionRate Decimal
  startDate      DateTime
  endDate        DateTime?
  status         String    @default("active")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}

model SubscriptionMember {
  id                    String             @id @default(cuid())
  customerId            String
  planId                String
  status                SubscriptionStatus @default(ACTIVE)
  startDate             DateTime
  renewalDate           DateTime?
  cancelledAt           DateTime?
  loyaltyMonths         Int                @default(0)
  loyaltyRewardAt       DateTime?
  renewalReminderSentAt DateTime? // Idempotent reminder tracking
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  // Relations
  customer Customer         @relation("CustomerSubscriptions", fields: [customerId], references: [id])
  plan     SubscriptionPlan @relation("PlanMembers", fields: [planId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([renewalDate])
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  company      String?
  email        String?
  phone        String?
  source       String?
  stage        LeadStage @default(LEAD)
  notes        String?
  followUpAt   DateTime?
  closedAt     DateTime?
  assignedToId String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  assignedTo User? @relation("LeadAssignee", fields: [assignedToId], references: [id])
  createdBy  User  @relation("LeadCreator", fields: [createdById], references: [id])

  @@index([stage])
  @@index([followUpAt])
  @@index([assignedToId])
}

model PromotionalPricing {
  id              String   @id @default(cuid())
  productId       String
  name            String
  discountPercent Decimal?
  fixedPrice      Decimal?
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([startDate])
  @@index([endDate])
  @@index([isActive])
}

// ============================================================================
// DOCUMENT MANAGEMENT MODELS (Phase 8)
// ============================================================================

model Document {
  id             String           @id @default(cuid())
  name           String
  category       DocumentCategory
  currentBlobUrl String
  isTemplate     Boolean          @default(false)

  // Polymorphic nullable FKs — at most one is non-null
  customerId String?
  orderId    String?
  batchId    String?

  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  customer   Customer?         @relation("CustomerDocuments", fields: [customerId], references: [id])
  order      Order?            @relation("OrderDocuments", fields: [orderId], references: [id])
  batch      Batch?            @relation("BatchDocuments", fields: [batchId], references: [id])
  uploadedBy User              @relation("DocumentUploader", fields: [uploadedById], references: [id])
  versions   DocumentVersion[]

  @@index([category])
  @@index([customerId])
  @@index([orderId])
  @@index([batchId])
  @@index([uploadedById])
  @@index([isTemplate])
  @@index([createdAt])
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  versionNumber Int
  blobUrl       String
  fileName      String
  fileSize      Int
  uploadedById  String
  createdAt     DateTime @default(now())

  // Relations
  document   Document @relation(fields: [documentId], references: [id])
  uploadedBy User     @relation("VersionUploader", fields: [uploadedById], references: [id])

  @@index([documentId])
  @@index([uploadedById])
  @@index([versionNumber])
}
