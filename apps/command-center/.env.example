# ============================================================================
# JHB Command Center — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development.
# Set these variables in your Vercel project settings for production.
# NEVER commit .env or .env.local files to git.
# ============================================================================

# ----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# ----------------------------------------------------------------------------
# Pooled connection — used by Prisma at runtime (PrismaNeon adapter)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Direct (non-pooled) connection — used by Prisma migrate deploy at build time
DIRECT_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-your-endpoint.us-east-2.aws.neon.tech/neondb?sslmode=require

# ----------------------------------------------------------------------------
# Authentication
# ----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-32-character-random-string-here

# ----------------------------------------------------------------------------
# Application URL
# ----------------------------------------------------------------------------
# Local: http://localhost:3000
# Production: https://command-center.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# ----------------------------------------------------------------------------
# Payments (Stripe)
# ----------------------------------------------------------------------------
# Use sk_live_... for production, sk_test_... for testing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Get from Stripe Dashboard > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ----------------------------------------------------------------------------
# Notifications (Slack)
# ----------------------------------------------------------------------------
# Optional — enables order shipping notifications in Slack.
# Create an incoming webhook at: https://api.slack.com/apps
# If not set, notifications are logged to console instead.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ----------------------------------------------------------------------------
# Internal APIs
# ----------------------------------------------------------------------------
# Shared secret for /api/incoming-order endpoint (Stripe + Etsy webhooks)
# Generate with: openssl rand -hex 16
WEBHOOK_API_KEY=your-internal-webhook-api-key

# ----------------------------------------------------------------------------
# Square POS Integration
# ----------------------------------------------------------------------------
# Get from: https://developer.squareup.com/apps -> your app -> Credentials tab
# Use Sandbox Access Token for testing, Production Access Token for live data
SQUARE_ACCESS_TOKEN=EAAAl_your_square_access_token_here
# Set to 'sandbox' for testing or 'production' for real sales data
SQUARE_ENVIRONMENT=sandbox

# ----------------------------------------------------------------------------
# Etsy Marketplace Integration
# ----------------------------------------------------------------------------
# Get from: https://www.etsy.com/developers/your-apps -> your app
ETSY_API_KEY=your_etsy_api_key_here
ETSY_SHOP_ID=your_etsy_shop_id
ETSY_ACCESS_TOKEN=your_etsy_oauth_access_token

# ----------------------------------------------------------------------------
# UPS Shipping Integration
# ----------------------------------------------------------------------------
# Get from: https://developer.ups.com/apps -> your app -> Credentials
UPS_CLIENT_ID=your_ups_client_id
UPS_CLIENT_SECRET=your_ups_client_secret
UPS_ACCOUNT_NUMBER=your_ups_account_number
